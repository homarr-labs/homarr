{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@site/*": ["./*"]
    },
  },
  "include": [
    "**/*.ts",
    "**/*.jsx",
    "**/*.js",
    "**/*.tsx",
    "**/*.md",
    "**/*.mdx",
  ],
  "exclude": ["node_modules"],
}
