{
  "$schema": "https://turborepo.org/schema.json",
  "globalEnv": ["CI", "NODE_ENV", "SKIP_ENV_VALIDATION"],
  "ui": "stream",
  "futureFlags": {
    "affectedUsingTaskInputs": true
  },
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AUTH_LDAP_BASE",
        "AUTH_LDAP_BIND_DN",
        "AUTH_LDAP_BIND_PASSWORD",
        "AUTH_LDAP_GROUP_CLASS",
        "AUTH_LDAP_GROUP_FILTER_EXTRA_ARG",
        "AUTH_LDAP_GROUP_MEMBER_ATTRIBUTE",
        "AUTH_LDAP_GROUP_MEMBER_USER_ATTRIBUTE",
        "AUTH_LDAP_SEARCH_SCOPE",
        "AUTH_LDAP_URI",
        "AUTH_LDAP_USERNAME_ATTRIBUTE",
        "AUTH_LDAP_USER_MAIL_ATTRIBUTE",
        "AUTH_LDAP_USERNAME_FILTER_EXTRA_ARG",
        "AUTH_OIDC_AUTO_LOGIN",
        "AUTH_OIDC_CLIENT_ID",
        "AUTH_OIDC_CLIENT_NAME",
        "AUTH_OIDC_CLIENT_SECRET",
        "AUTH_OIDC_FORCE_USERINFO",
        "AUTH_OIDC_GROUPS_ATTRIBUTE",
        "AUTH_OIDC_ISSUER",
        "AUTH_OIDC_NAME_ATTRIBUTE_OVERWRITE",
        "AUTH_OIDC_SCOPE_OVERWRITE",
        "AUTH_LOGOUT_REDIRECT_URL",
        "AUTH_PROVIDERS",
        "AUTH_SESSION_EXPIRY_TIME",
        "DB_DRIVER",
        "DB_HOST",
        "DB_NAME",
        "DB_PASSWORD",
        "DB_PORT",
        "DB_URL",
        "DB_USER",
        "DISABLE_REDIS_LOGS",
        "DOCKER_HOSTNAMES",
        "DOCKER_PORTS",
        "DOCKER_SOCKET_PATHS",
        "LOCAL_CERTIFICATE_PATH",
        "LOG_LEVEL",
        "PORT",
        "SECRET_ENCRYPTION_KEY"
      ],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.ts", "!**/*.test.tsx", "!**/*.spec.ts", "!**/__tests__/**"],
      "outputs": [".next/**", "!.next/cache/**", "next-env.d.ts", ".output/**", ".vercel/output/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "format": {
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["node_modules/.cache/.prettiercache"],
      "outputLogs": "new-only"
    },
    "lint": {
      "dependsOn": ["^topo"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["node_modules/.cache/.eslintcache"]
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "inputs": ["$TURBO_DEFAULT$", "!**/*.test.ts", "!**/*.test.tsx", "!**/*.spec.ts", "!**/__tests__/**"],
      "outputs": ["node_modules/.cache/tsbuildinfo.json"]
    },
    "clean": {
      "cache": false
    },
    "//#clean": {
      "cache": false
    }
  }
}
