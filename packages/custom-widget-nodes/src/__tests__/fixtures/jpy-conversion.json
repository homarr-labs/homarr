{
  "$schema": "homarr-custom-widget-v1",
  "name": "50 JPY Conversion",
  "description": "Converts 50 Japanese Yen into Euros and US Dollars using the Frankfurter API (European Central Bank rates)",
  "baseUrl": "https://api.frankfurter.dev",
  "authType": "none",
  "endpoint": "/v1/latest?from=JPY&to=EUR,USD&amount=50",
  "method": "GET",
  "displayType": "keyValue",
  "displayConfig": {
    "type": "keyValue",
    "mappings": [
      { "label": "50 JPY → EUR", "jsonPath": "$.rates.EUR", "unit": "€" },
      { "label": "50 JPY → USD", "jsonPath": "$.rates.USD", "unit": "$" }
    ]
  }
}
