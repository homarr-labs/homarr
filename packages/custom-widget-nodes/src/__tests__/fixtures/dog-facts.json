{
  "$schema": "homarr-custom-widget-v1",
  "name": "Random Dog Fact",
  "description": "Displays a random fun fact about dogs from the Dog API",
  "baseUrl": "https://dogapi.dog",
  "authType": "none",
  "endpoint": "/api/v2/facts",
  "method": "GET",
  "displayType": "singleValue",
  "displayConfig": {
    "type": "singleValue",
    "jsonPath": "$.data[0].attributes.body",
    "label": "Dog Fact 🐕",
    "unit": ""
  }
}
